# Credenciales de cuenta de servicio de Google (obligatorio)
# Crea una cuenta de servicio en Google Cloud, habilita la Google Drive API
# y comparte la carpeta de Drive con el email de la cuenta de servicio.
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=tu-service-account@tu-proyecto.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...tu clave...\n-----END PRIVATE KEY-----\n"

# Opción A: Una sola carpeta (igual que antes)
# Obtén el ID desde la URL al abrir la carpeta: drive.google.com/drive/folders/ESTE_ES_EL_ID
GOOGLE_DRIVE_FOLDER_ID=id-de-tu-carpeta

# Opción B: Varias carpetas con nombre para la UI (orden = orden en el sidebar)
# Formato JSON: [{"id":"id-carpeta-1","name":"Nombre visible"},{"id":"id-carpeta-2","name":"Otra carpeta"}]
# Si defines GOOGLE_DRIVE_FOLDERS, GOOGLE_DRIVE_FOLDER_ID se ignora.
#GOOGLE_DRIVE_FOLDERS=[{"id":"id-1","name":"Tutoriales"},{"id":"id-2","name":"Grabaciones"}]

# (Opcional) NextAuth/Auth.js si quieres añadir login de usuarios más adelante
#AUTH_SECRET=genera-una-clave-secreta-con-openssl-rand-base64-32
#AUTH_GOOGLE_ID=tu-client-id.apps.googleusercontent.com
#AUTH_GOOGLE_SECRET=tu-client-secret
