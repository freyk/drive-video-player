# Google service account credentials (required)
# Create a service account in Google Cloud, enable the Google Drive API,
# and share the Drive folder with the service account email.
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...your key...\n-----END PRIVATE KEY-----\n"

# Option A: Single folder (same as before)
# Get the ID from the URL when you open the folder: drive.google.com/drive/folders/THIS_IS_THE_ID
GOOGLE_DRIVE_FOLDER_ID=your-folder-id

# Option B: Multiple named folders for the UI (order = order in sidebar)
# JSON format: [{"id":"folder-id-1","name":"Display name"},{"id":"folder-id-2","name":"Another folder"}]
# If you set GOOGLE_DRIVE_FOLDERS, GOOGLE_DRIVE_FOLDER_ID is ignored.
#GOOGLE_DRIVE_FOLDERS=[{"id":"id-1","name":"Tutorials"},{"id":"id-2","name":"Recordings"}]

# (Optional) NextAuth/Auth.js if you want to add user login later
#AUTH_SECRET=generate-a-secret-key-with-openssl-rand-base64-32
#AUTH_GOOGLE_ID=your-client-id.apps.googleusercontent.com
#AUTH_GOOGLE_SECRET=your-client-secret
